          },
          {
            "name": "variant",
            "expr": "source.variant",
            "displayName": "Variant"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "name": "total_revenue",
            "expr": "SUM(source.total_amount_inr)",
            "displayName": "Total Revenue (INR)"
          },
          {
            "name": "total_quantity",
            "expr": "SUM(source.sold_quantity)",
            "displayName": "Total Quantity Sold"
          },
          {
            "name": "avg_price",
            "expr": "AVG(source.price_inr)",
            "displayName": "Average Price (INR)"
          },
          {
            "name": "order_count",
            "expr": "COUNT(DISTINCT CONCAT(source.customer_code, '-', source.date_key, '-', source.product_code))",
            "displayName": "Order Count"
          }
        ]
      }
    },
    {
      "name": "top_10_customers",
      "displayName": "Top 10 Customers",
      "queryLines": [
        "SELECT\n",
        "  customer,\n",
        "  SUM(total_amount_inr) as total_revenue,\n",
        "  SUM(sold_quantity) as total_quantity\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  customer\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    },
    {
      "name": "top_10_products",
      "displayName": "Top 10 Products",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  division,\n",
        "  category,\n",
        "  SUM(total_amount_inr) as total_revenue,\n",
        "  SUM(sold_quantity) as total_quantity\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  product,\n",
        "  division,\n",
        "  category\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    }
